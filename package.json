{
  "name": "react-native-smart-otp",
  "version": "1.0.0",
  "description": "Enterprise-grade OTP / PIN input for React Native and Expo with autofill, accessibility, theming and the New Architecture.",
  "main": "./lib/commonjs/index.js",
  "module": "./lib/module/index.js",
  "types": "./lib/typescript/commonjs/src/index.d.ts",
  "react-native": "src/index.tsx",
  "source": "src/index.tsx",
  "exports": {
    ".": {
      "import": {
        "types": "./lib/typescript/module/src/index.d.ts",
        "default": "./lib/module/index.js"
      },
      "require": {
        "types": "./lib/typescript/commonjs/src/index.d.ts",
        "default": "./lib/commonjs/index.js"
      }
    },
    "./package.json": "./package.json",
    "./app.plugin.js": "./app.plugin.js"
  },
  "files": [
    "src",
    "lib",
    "android",
    "app.plugin.js",
    "!android/build",
    "!android/gradle",
    "!**/__tests__",
    "!**/__mocks__",
    "!**/*.map",
    "!**/.*"
  ],
  "sideEffects": false,
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "format": "prettier --check \"src/**/*.{ts,tsx}\"",
    "test": "jest",
    "build": "bob build",
    "size": "size-limit",
    "prepack": "bob build",
    "clean": "del-cli lib"
  },
  "keywords": [
    "react-native",
    "expo",
    "otp",
    "pin",
    "one-time-password",
    "sms",
    "autofill",
    "sms-retriever",
    "accessibility",
    "turbomodule",
    "fabric",
    "new-architecture"
  ],
  "license": "MIT",
  "author": "react-native-smart-otp contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/seaculum/react-native-smart-otp.git"
  },
  "peerDependencies": {
    "@react-native-clipboard/clipboard": "*",
    "react": "*",
    "react-native": "*"
  },
  "peerDependenciesMeta": {
    "@react-native-clipboard/clipboard": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@react-native/babel-preset": "0.86.0",
    "@react-native/jest-preset": "^0.86.0",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/git": "10.0.1",
    "@size-limit/preset-small-lib": "12.1.0",
    "@testing-library/react-native": "14.0.1",
    "@types/jest": "30.0.0",
    "@types/react": "19.2.17",
    "@typescript-eslint/eslint-plugin": "8.63.0",
    "@typescript-eslint/parser": "8.63.0",
    "del-cli": "7.0.0",
    "eslint": "9.39.4",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.7.0",
    "jest": "30.4.2",
    "prettier": "3.9.4",
    "react": "19.2.7",
    "react-hook-form": "7.81.0",
    "react-native": "0.86.0",
    "react-native-builder-bob": "0.43.0",
    "semantic-release": "25.0.5",
    "size-limit": "12.1.0",
    "test-renderer": "1.2.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0"
  },
  "codegenConfig": {
    "name": "RNSmartOtpSpec",
    "type": "modules",
    "jsSrcsDir": "src/specs",
    "android": {
      "javaPackageName": "com.smartotp"
    }
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "commonjs",
        {
          "esm": true
        }
      ],
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript"
      ]
    ]
  },
  "jest": {
    "preset": "@react-native/jest-preset",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.ts"
    ],
    "modulePathIgnorePatterns": [
      "<rootDir>/lib/"
    ],
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/**/*.d.ts",
      "!src/**/__tests__/**"
    ]
  },
  "overrides": {
    "@react-native/jest-preset": {
      "jest-environment-node": "^30.0.0",
      "babel-jest": "^30.0.0"
    }
  }
}
